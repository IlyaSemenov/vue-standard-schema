{
  "name": "vue-standard-schema",
  "type": "module",
  "version": "4.0.1",
  "packageManager": "bun@1.3.9",
  "description": "Vue3 composables for handling form submit with Standard Schema validation support",
  "author": "Ilya Semenov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/IlyaSemenov/vue-standard-schema"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "files": [
    "!src/**/*.test.*",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint --fix .",
    "prepare": "lefthook install",
    "prepublishOnly": "bun run build",
    "test": "bun test && bun run types",
    "types": "tsgo"
  },
  "peerDependencies": {
    "@vue/reactivity": "^3",
    "@vue/runtime-core": "^3"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.0.0",
    "@standard-schema/utils": "^0.3.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.26.2",
    "@ilyasemenov/eslint-config": "^1.4.2",
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "^1.3.10",
    "@typescript/native-preview": "^7.0.0-dev.20260311.1",
    "@vue/reactivity": "^3.4.29",
    "@vue/runtime-core": "^3.4.29",
    "eslint": "^9.35.0",
    "tsup": "^8.5.0",
    "typescript": "^5.4.5",
    "valibot": "^1.1.0",
    "zod": "^4.1.7"
  }
}
